# Copy this file to .env and fill in your credentials.
# The .env file is git-ignored and never committed to the repository.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your actual keys
#
# All scripts load this file automatically via size_utils.load_env().
# Shell environment variables take precedence over .env values.

# ---------------------------------------------------------------------------
# OpenAI API key — required for:
#   generate_finance_cot.py   (75K chain-of-thought SFT examples)
#   generate_finance_code.py  (7.5K finance Python code SFT examples)
#
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---------------------------------------------------------------------------
# Kaggle API credentials — optional, enables Kaggle notebook collection in:
#   prepare_code_data.py      (pretraining code data)
#   tok_train.py              (tokenizer code data)
#
# Get yours at: https://www.kaggle.com/settings → API → Create New Token
# This downloads a kaggle.json — copy the username and key from it.
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ---------------------------------------------------------------------------
# HuggingFace token — required for gated datasets (The Stack, some others)
#
# Get yours at: https://huggingface.co/settings/tokens
# Only needed if you use --source stack in prepare_code_data.py
HF_TOKEN=hf_your-huggingface-token-here

# ---------------------------------------------------------------------------
# RunPod S3 credentials — required for download_model.py
# Used to download trained model checkpoints from a RunPod network volume.
#
# Get yours at: RunPod dashboard → Storage → <your volume> → Manage → API Keys
# Create an Access Key + Secret Key pair.
RUNPOD_S3_ENDPOINT=https://s3api-us-ca-2.runpod.io
RUNPOD_S3_BUCKET=your-volume-id-here
RUNPOD_S3_ACCESS_KEY=your-runpod-s3-access-key
RUNPOD_S3_SECRET_KEY=your-runpod-s3-secret-key
